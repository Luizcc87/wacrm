# --- Application Config ---
WEB_PORT=80
APP_URL=https://yourdomain.com

# --- Database Config ---
# Option 1: Supabase Cloud (Use your remote connection pool URL)
# DATABASE_URL=postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Option 2: Localhost with Supabase (If running Supabase Docker locally)
# DATABASE_URL=postgres://postgres:postgres@localhost:54322/postgres

# Option 3: Local Postgres Container (The 'db' service in docker-compose.yml)
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgres://postgres:your_secure_password_here@db:5432/postgres
